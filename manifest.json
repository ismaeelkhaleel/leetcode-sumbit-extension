{
  "manifest_version": 3,
  "name": "LeetCode Sync",
  "version": "1.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*",
    "https://api.groq.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*"
      ],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js"
      ],
      "matches": [
        "https://leetcode.com/*"
      ]
    }
  ]
}